# Variables de entorno para Campus Duomo LMS
# ============================================

# MODO DE AUTENTICACIÓN
# Opciones: 'demo' o 'moodle'
# - demo: Usa credenciales de prueba locales
# - moodle: Se conecta a Moodle via Web Services
VITE_AUTH_MODE=moodle

# ============================================
# CONFIGURACIÓN MOODLE - BACKEND REAL
# ============================================

# URL base del sitio Moodle (sin barra final)
VITE_MOODLE_BASE_URL=https://campus.duomo.com.ar

# URL base de la API de Moodle
VITE_MOODLE_API_URL=https://campus.duomo.com.ar/webservice/rest/server.php

# URL para login de Moodle (token.php)
VITE_MOODLE_LOGIN_URL=https://campus.duomo.com.ar/login/token.php

# URL para subida de archivos
VITE_MOODLE_UPLOAD_URL=https://campus.duomo.com.ar/webservice/upload.php

# Nombre del servicio configurado en Moodle
VITE_MOODLE_SERVICE=frontend

# Formato de respuesta de Moodle
VITE_MOODLE_FORMAT=moodlewsrestformat=json

# Token de desarrollo (opcional, solo para pruebas)
# VITE_MOODLE_TOKEN=25edc96999eb7d055455cdb3d53d0db7

# ============================================
# CONFIGURACIÓN DE LA APP
# ============================================

# Nombre de la aplicación
VITE_APP_NAME=Campus Duomo

# Versión de la aplicación
VITE_APP_VERSION=1.0.0

# Entorno: development, staging, production
VITE_APP_ENV=production
